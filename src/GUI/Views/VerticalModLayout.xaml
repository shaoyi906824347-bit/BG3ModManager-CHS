<UserControl
	x:Class="DivinityModManager.Views.VerticalModLayout"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DivinityModManager.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:data="clr-namespace:DivinityModManager.Models;assembly=DivinityModManagerCore"
	xmlns:dd="urn:gong-wpf-dragdrop"
	xmlns:local="clr-namespace:DivinityModManager.Views"
	xmlns:localization="clr-namespace:DivinityModManager.Localization;assembly=DivinityModManagerCore"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:DivinityModManager.ViewModels"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.Resources>
		<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
	</UserControl.Resources>
	<Grid x:Name="VerticalGridLayout">
		<Grid.RowDefinitions>
			<RowDefinition Height="2*" />
			<RowDefinition Height="4" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Padding="4"
				    Text="已启用模组"
				    ToolTip="会加载进游戏的模组，顺序从上到下依次生效。排在下方的模组通常会覆盖上方模组的同名内容。" />
				<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
					<TextBlock Text="汉化：" FontSize="11" Opacity="0.8" VerticalAlignment="Center" />
					<TextBlock Text="{x:Static localization:BrandText.Translator}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
					<TextBlock Text="  反馈邮箱：" FontSize="11" Margin="10,0,0,0" Opacity="0.8" VerticalAlignment="Center" />
					<controls:HyperlinkText DisplayText="{x:Static localization:BrandText.FeedbackEmail}" URL="mailto:bg3modfeedback@163.com" FontSize="11" VerticalAlignment="Center" />
				</StackPanel>
			</Grid>
			<controls:ModListView
				Grid.Row="1"
				dd:DragDrop.IsDragSource="True"
				dd:DragDrop.IsDropTarget="True"
				ItemsSource="{Binding ActiveMods}"
				Style="{StaticResource ModOrderListView}"
				View="{DynamicResource ModGridView}" />
		</Grid>
		<GridSplitter
			Grid.Row="1"
			Height="4"
			HorizontalAlignment="Stretch" />
		<Grid Grid.Row="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<TextBlock Padding="4"
			    Text="未启用模组"
			    ToolTip="已安装但当前不会加载的模组。双击或按回车即可移到已启用列表。" />
			<controls:ModListView
				Grid.Row="1"
				dd:DragDrop.DropHandler="{Binding}"
				dd:DragDrop.IsDragSource="True"
				dd:DragDrop.IsDropTarget="True"
				ItemsSource="{Binding InactiveMods}"
				Style="{StaticResource ModOrderListView}"
				View="{DynamicResource InactiveModGridView}" />
		</Grid>
	</Grid>
</UserControl>

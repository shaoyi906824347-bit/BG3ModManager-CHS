<local:AboutWindowBase x:Class="DivinityModManager.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:DivinityModManager;assembly=DivinityModManagerCore"
    xmlns:c="clr-namespace:DivinityModManager.Controls"
    xmlns:controls="clr-namespace:DivinityModManager.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:DivinityModManager.Controls.Extensions"
    xmlns:local="clr-namespace:DivinityModManager.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="关于软件"
    Width="600"
    Height="380"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
	<Window.Style>
		<Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window" />
	</Window.Style>
	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>
	<controls:AutoGrid Margin="16"
	    Columns="*"
	    RowCount="5"
	    Rows="auto,auto,auto,*,auto">
		<TextBlock x:Name="TitleText"
		    HorizontalAlignment="Center"
		    FontSize="18"
		    TextAlignment="Center" />
		<Separator Margin="0,4" />
		<controls:AutoGrid HorizontalAlignment="Center"
		    ColumnCount="2"
		    Columns="1*,3*"
		    RowCount="5"
		    Rows="auto,auto,auto,auto,auto">
			<TextBlock HorizontalAlignment="Right" Text="官方主页:" />
			<c:HyperlinkText Margin="10,0,0,4"
			    HorizontalAlignment="Left"
			    URL="{x:Static app:DivinityApp.URL_REPO}"
			    UseUrlForDisplayText="True" />
			<TextBlock Margin="0,0,0,4"
			    HorizontalAlignment="Right"
			    Text="软件作者:"
			    TextAlignment="Left" />
			<c:HyperlinkText Margin="10,0,0,0"
			    HorizontalAlignment="Left"
			    DisplayText="LaughingLeader"
			    URL="{x:Static app:DivinityApp.URL_AUTHOR}" />
			<TextBlock HorizontalAlignment="Right" Text="汉化:" />
			<TextBlock Margin="10,0,0,4"
			    HorizontalAlignment="Left"
			    Text="可爱女陔王语嫣 (小黑盒 ID: 29602586)" />
			<TextBlock HorizontalAlignment="Right" Text="反馈邮箱:" />
			<c:HyperlinkText Margin="10,0,0,4"
			    HorizontalAlignment="Left"
			    DisplayText="bg3modfeedback@163.com"
			    URL="mailto:bg3modfeedback@163.com" />
			<TextBlock HorizontalAlignment="Right" Text="开源许可:" />
			<c:HyperlinkText Margin="10,0,0,4"
			    HorizontalAlignment="Left"
			    DisplayText="MIT 2019"
			    URL="{x:Static app:DivinityApp.URL_LICENSE}" />
		</controls:AutoGrid>
		<StackPanel Orientation="Vertical">
			<TextBlock HorizontalAlignment="Center"
			    FontSize="16"
			    Text="支持与反馈"
			    TextAlignment="Center" />
			<Separator Margin="0,4" />
			<controls:AutoGrid HorizontalAlignment="Center"
			    ColumnCount="2"
			    Columns="1*,3*"
			    RowCount="3"
			    Rows="auto,auto,auto">
				<TextBlock HorizontalAlignment="Right" Text="请作者喝杯咖啡:" />
				<c:HyperlinkText Margin="10,0,0,4"
				    HorizontalAlignment="Left"
				    URL="{x:Static app:DivinityApp.URL_DONATION}"
				    UseUrlForDisplayText="True" />
				<TextBlock HorizontalAlignment="Right" Text="提交 Bug / 建议:" />
				<c:HyperlinkText Margin="10,0,0,4"
				    HorizontalAlignment="Left"
				    URL="{x:Static app:DivinityApp.URL_ISSUES}"
				    UseUrlForDisplayText="True" />
				<TextBlock HorizontalAlignment="Right" Text="更新日志:" />
				<c:HyperlinkText Margin="10,0,0,4"
				    HorizontalAlignment="Left"
				    URL="{x:Static app:DivinityApp.URL_CHANGELOG}"
				    UseUrlForDisplayText="True" />
			</controls:AutoGrid>
		</StackPanel>
		<TextBlock Margin="0,12,0,0"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Bottom"
		    FontSize="11"
		    FontStyle="Italic"
		    Opacity="0.8"
		    Text="本汉化版本完全免费，仅供国内博德之门3玩家及模组爱好者交流学习使用。&#x0a;特别感谢所有分享模组与提出宝贵建议的冒险者！"
		    TextAlignment="Center"
		    TextWrapping="Wrap" />
	</controls:AutoGrid>
</local:AboutWindowBase>
